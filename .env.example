# Secrets (env only, never committed)
OPENROUTER_API_KEY=

# Database
# Default: SQLite file in ./data/webarhive.db
# Postgres example: postgresql+asyncpg://user:pass@host:5432/webarhive
DATABASE_URL=sqlite+aiosqlite:///./data/webarhive.db

# LLM models per role (see spec section 9)
# Use any model id from OpenRouter; each role can use a different one.
MODEL_CLASSIFICATION=openai/gpt-4o-mini
MODEL_VERDICT=openai/gpt-4o-mini
MODEL_SMART_DROP=openai/gpt-4o-mini
MODEL_REDIRECT=openai/gpt-4o-mini

# LLM role flags (spec section 9)
ENABLE_VERDICT=true
ENABLE_SMART_DROP=false
ENABLE_REDIRECT_LLM=false

# Budgets and limits
MAX_LLM_CALLS_PER_DOMAIN=40
COST_BUDGET_PER_DOMAIN=0.5
TEXT_LIMIT=2000
TITLE_SHIFT_THRESHOLD=2

# Concurrency & throttling
CONCURRENCY=4
IA_RATE_LIMIT=4
IA_BACKOFF=2.0
IA_MAX_RETRIES=5

# Input handling
CHECK_SUBDOMAINS=false

# App
APP_DOMAIN=checker.local
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
TRUST_PROXY_HEADERS=true
